{
  "name": "catalogo-filmes",
  "version": "1.0.0",
  "description": "Catálogo pessoal de filmes, séries, documentários e outros formatos",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node dev-runner.js",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "jest --forceExit",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^5.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "jest": "^30.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ednelson.meu-catalogo",
    "productName": "Meu Catálogo",
    "icon": "icon.png",
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icon.png",
      "node_modules/better-sqlite3/build/**/*",
      "node_modules/better-sqlite3/lib/**/*",
      "node_modules/better-sqlite3/package.json"
    ],
    "npmRebuild": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerLanguages": [
        "pt_BR"
      ],
      "language": "1046"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": {
    "name": "Ednelson Santos",
    "url": "https://github.com/ednelsonsantos"
  },
  "license": "GPL-3.0-or-later"
}
